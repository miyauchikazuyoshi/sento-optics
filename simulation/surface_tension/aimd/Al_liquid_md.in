&CONTROL
    calculation   = 'md'
    restart_mode  = 'from_scratch'
    prefix        = 'Al_liquid'
    outdir        = './tmp/'
    pseudo_dir    = '../qe_slab/pseudo/'
    tprnfor       = .true.
    tstress       = .true.
    dt            = 20.0
    nstep         = 5000
    verbosity     = 'high'
/

&SYSTEM
    ibrav         = 1
    celldm(1)     = 20.122350
    nat           = 64
    ntyp          = 1
    ecutwfc       = 40.0
    ecutrho       = 320.0
    occupations   = 'smearing'
    smearing      = 'mv'
    degauss       = 0.02
    nosym         = .true.
    noinv         = .true.
    nbnd          = 125
/

&ELECTRONS
    electron_maxstep = 200
    conv_thr         = 1.0d-6
    mixing_beta      = 0.3
    mixing_mode      = 'plain'
    diagonalization  = 'david'
/

&IONS
    ion_dynamics    = 'verlet'
    ion_temperature = 'andersen'
    tempw           = 1033.0
    nraise          = 50
/

