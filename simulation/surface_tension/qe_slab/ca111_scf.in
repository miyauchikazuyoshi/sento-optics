&CONTROL
  calculation  = 'scf'
  prefix       = 'ca111'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
  tprnfor      = .true.
  tstress      = .true.
/

&SYSTEM
  ibrav        = 0
  nat          = 7
  ntyp         = 1
  ecutwfc      = 30.0
  ecutrho      = 240.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
  nosym        = .true.
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'local-TF'
/

ATOMIC_SPECIES
  Ca  40.0780  Ca.pbe-spn-kjpaw_psl.1.0.0.UPF

