&CONTROL
  calculation  = 'scf'
  prefix       = 'cu111'
  outdir       = './tmp_cu/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
  tprnfor      = .true.
/

&SYSTEM
  ibrav        = 0
  nat          = 7
  ntyp         = 1
  ecutwfc      = 40.0
  ecutrho      = 320.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
  nosym        = .true.
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'local-TF'
/

ATOMIC_SPECIES
  Cu  63.546  Cu.pbe-dn-kjpaw_psl.1.0.0.UPF

! Cu FCC: a = 3.615 Ang
! (111) surface
! In-plane: a/sqrt(2) = 2.556 Ang
! Interlayer spacing d(111) = a/sqrt(3) = 2.087 Ang
! 7 layers + 15 Ang vacuum

CELL_PARAMETERS angstrom
  2.5560  0.0000  0.0000
  1.2780  2.2130  0.0000
  0.0000  0.0000  29.6090

ATOMIC_POSITIONS angstrom
  Cu  0.0000  0.0000   0.0000
  Cu  1.2780  0.7377   2.0870
  Cu  0.0000  1.4753   4.1740
  Cu  0.0000  0.0000   6.2610
  Cu  1.2780  0.7377   8.3480
  Cu  0.0000  1.4753  10.4350
  Cu  0.0000  0.0000  12.5220

K_POINTS automatic
  8 8 1  0 0 0
