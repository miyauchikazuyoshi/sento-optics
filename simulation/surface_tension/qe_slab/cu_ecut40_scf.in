&CONTROL
  calculation  = 'scf'
  prefix       = 'cu_ecut40'
  outdir       = './tmp_conv/cu_ecut40/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
/

&SYSTEM
  ibrav        = 0
  nat          = 7
  ntyp         = 1
  ecutwfc      = 40.0
  ecutrho      = 320.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
  nosym        = .true.
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'local-TF'
/

ATOMIC_SPECIES
  Cu  63.5460  Cu.pbe-dn-kjpaw_psl.1.0.0.UPF

