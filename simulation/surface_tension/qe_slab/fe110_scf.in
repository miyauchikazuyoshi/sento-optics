&CONTROL
  calculation  = 'scf'
  prefix       = 'fe110'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
  tprnfor      = .true.
  tstress      = .true.
/

&SYSTEM
  ibrav        = 0
  nat          = 7
  ntyp         = 1
  ecutwfc      = 50.0
  ecutrho      = 400.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
  nosym        = .true.
  nspin        = 2
  starting_magnetization(1) = 0.3
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'local-TF'
/

ATOMIC_SPECIES
  Fe  55.8450  Fe.pbe-spn-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  2.870000  0.000000  0.000000
  0.000000  2.029396  0.000000
  0.000000  0.000000  27.176379

ATOMIC_POSITIONS angstrom
  Fe  0.000000  0.000000  0.000000
  Fe  1.435000  1.014698  2.029396
  Fe  0.000000  0.000000  4.058793
  Fe  1.435000  1.014698  6.088189
  Fe  0.000000  0.000000  8.117586
  Fe  1.435000  1.014698  10.146982
  Fe  0.000000  0.000000  12.176379

K_POINTS automatic
  8 8 1  0 0 0
