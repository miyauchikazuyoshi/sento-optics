&CONTROL
  calculation  = 'scf'
  prefix       = 'ni111'
  outdir       = './tmp/'
  pseudo_dir   = './pseudo/'
  verbosity    = 'high'
  tprnfor      = .true.
  tstress      = .true.
/

&SYSTEM
  ibrav        = 0
  nat          = 7
  ntyp         = 1
  ecutwfc      = 50.0
  ecutrho      = 400.0
  occupations  = 'smearing'
  smearing     = 'mp'
  degauss      = 0.02
  nosym        = .true.
  nspin        = 2
  starting_magnetization(1) = 0.2
/

&ELECTRONS
  conv_thr     = 1.0d-8
  mixing_beta  = 0.3
  mixing_mode  = 'local-TF'
/

ATOMIC_SPECIES
  Ni  58.6930  Ni.pbe-spn-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  2.489016  0.000000  0.000000
  1.244508  2.155551  0.000000
  0.000000  0.000000  27.193638

ATOMIC_POSITIONS angstrom
  Ni  0.000000  0.000000  0.000000
  Ni  1.244508  0.718517  2.032273
  Ni  2.489016  1.437034  4.064546
  Ni  0.000000  0.000000  6.096819
  Ni  1.244508  0.718517  8.129092
  Ni  2.489016  1.437034  10.161365
  Ni  0.000000  0.000000  12.193638

K_POINTS automatic
  8 8 1  0 0 0
