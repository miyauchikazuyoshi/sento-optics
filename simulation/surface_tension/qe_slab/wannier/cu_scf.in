&CONTROL
  calculation = 'scf'
  prefix      = 'cu_bulk'
  outdir      = './tmp_cu/'
  pseudo_dir  = '../pseudo/'
/
&SYSTEM
  ibrav       = 0
  nat         = 1
  ntyp        = 1
  ecutwfc     = 40.0
  ecutrho     = 320.0
  occupations = 'smearing'
  smearing    = 'mp'
  degauss     = 0.02
  nosym       = .true.
/
&ELECTRONS
  conv_thr = 1.0d-8
/
ATOMIC_SPECIES
  Cu  63.546  Cu.pbe-dn-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  -1.8074040435  0.0000000000  1.8074040435
  0.0000000000  1.8074040435  1.8074040435
  -1.8074040435  1.8074040435  0.0000000000

ATOMIC_POSITIONS crystal
  Cu  0.0  0.0  0.0

K_POINTS automatic
  8 8 8 0 0 0
