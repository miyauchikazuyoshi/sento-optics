&CONTROL
  calculation = 'scf'
  prefix      = 'na_bulk'
  outdir      = './tmp_na/'
  pseudo_dir  = '../pseudo/'
/
&SYSTEM
  ibrav       = 0
  nat         = 1
  ntyp        = 1
  ecutwfc     = 30.0
  ecutrho     = 240.0
  occupations = 'smearing'
  smearing    = 'mp'
  degauss     = 0.02
  nosym       = .true.
/
&ELECTRONS
  conv_thr = 1.0d-8
/
ATOMIC_SPECIES
  Na  22.9898  Na.pbe-spn-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  2.1124481252  2.1124481252  2.1124481252
  -2.1124481252  2.1124481252  2.1124481252
  -2.1124481252  -2.1124481252  2.1124481252

ATOMIC_POSITIONS crystal
  Na  0.0  0.0  0.0

K_POINTS automatic
  8 8 8 0 0 0
