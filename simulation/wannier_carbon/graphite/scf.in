&CONTROL
  calculation = 'scf'
  prefix      = 'graphite'
  outdir      = './tmp/'
  pseudo_dir  = '../pseudo/'
/
&SYSTEM
  ibrav       = 0
  nat         = 4
  ntyp        = 1
  ecutwfc     = 60.0
  ecutrho     = 480.0
  occupations = 'smearing'
  smearing    = 'gaussian'
  degauss     = 0.005
  nosym       = .true.
/
&ELECTRONS
  conv_thr = 1.0d-8
/
ATOMIC_SPECIES
  C  12.0107  C.pbe-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  2.4610000000  0.0000000000  0.0000000000
 -1.2305000000  2.1314570000  0.0000000000
  0.0000000000  0.0000000000  6.7080000000

ATOMIC_POSITIONS crystal
  C  0.000000  0.000000  0.250000
  C  0.000000  0.000000  0.750000
  C  0.333333  0.666667  0.250000
  C  0.666667  0.333333  0.750000

K_POINTS automatic
  8 8 4 0 0 0
